---
layout: 
title: 
permalink: /calendar/export.ics
# see RFC 2445 ("Internet Calendaring and Scheduling Core Object Specification (iCalendar)")
#TODO:
#- UID NOT unique if >1 event on same date
#- URL in DESCRIPTION breaks if non-site-relative path specified for event.event_date
#- Add time specification rather than strict all-day events
#- e.g. DT*:{{ event.event_date | date: "%Y%m%d" }}T235959Z
#- Test with unspecified event values. Consider defaults.
---
BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//iDigBio//NONSGML iCalendar Jeykll Templated//EN
METHOD:PUBLISH{% for event in site.events %}
BEGIN:VEVENT
UID:{{ event.event_date | date: "%Y%m%d" }}@idigbio.gbif.us
LOCATION:https://ufl.zoom.us/my/idigbio
SUMMARY:{{ event.title | remove: ',' | remove: ';' }}
DESCRIPTION:More information at {{ site.url }}{{ event.url }}
DTSTART;VALUE=DATE:{{ event.event_date | date: "%Y%m%d" }}
DTEND;VALUE=DATE:{{ event.event_date_end | date: "%Y%m%d" }}
DTSTAMP:{{ event.event_date | date: "%Y%m%d" }}T000000Z
END:VEVENT{% endfor %}
END:VCALENDAR